# ============================================
# SUPABASE (Database + Auth)
# ============================================
# Keep Supabase for database and authentication
# Free tier: 500MB database, unlimited API requests
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ============================================
# CLOUDFLARE R2 (Unlimited File Storage)
# ============================================
# R2 replaces Supabase Storage for large files
# Free tier: 10GB storage, 1M Class A / 10M Class B requests/month
# Set up: https://dash.cloudflare.com/r2
VITE_R2_ACCOUNT_ID=your-r2-account-id
VITE_R2_ACCESS_KEY_ID=your-access-key-id
VITE_R2_SECRET_ACCESS_KEY=your-secret-access-key
VITE_R2_BUCKET=templates
VITE_R2_PUBLIC_URL=https://your-domain.com/files
