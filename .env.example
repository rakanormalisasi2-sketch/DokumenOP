# Supabase Configuration
# Copy this file to .env and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Optional: Cloudflare R2 for large file storage (instead of Supabase Storage)
# VITE_R2_ACCOUNT_ID=your-r2-account-id
# VITE_R2_ACCESS_KEY_ID=your-access-key
# VITE_R2_SECRET_ACCESS_KEY=your-secret-key
# VITE_R2_BUCKET=your-bucket-name
# VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev
